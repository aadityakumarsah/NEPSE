# ── AI provider (required) ────────────────────────────────────────────────────
# Get a free key at https://console.groq.com
GROQ_API_KEY=key

# ── NEPSE price updater secret (required) ─────────────────────────────────────
# Any strong random string — used to protect /api/update-fundamentals
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEPSE_UPDATE_SECRET=your_strong_random_secret_here

# ── App base URL ──────────────────────────────────────────────────────────────
# Local development
BASE_URL=http://localhost:3000
# Production (set this in Vercel dashboard instead)
# BASE_URL=https://your-app.vercel.app
